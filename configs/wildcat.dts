/dts-v1/;

/ {
	#address-cells = <1>;
	#size-cells = <1>;
	compatible = "riscv-minimal-nommu,wildcat";
	model = "riscv-minimal-nommu,wildcat";

	chosen {
		bootargs = "earlycon=ns16850,mmio,0x10000000 console=ttyS0 debug";
	};

	memory@80000000 {
        device_type = "memory";
        reg = <0x80000000 0x00800000>;
    };

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;
		timebase-frequency = <10000000>;

		cpu@0 {
			device_type = "cpu";
			reg = <0>;
			status = "okay";
			compatible = "riscv";
			riscv,isa-base = "rv32ima";
			riscv,isa-extensions = "i", "m", "a", "zicsr", "zifencei";
			mmu-type = "riscv,none";

			interrupt-controller {
				#interrupt-cells = <0x01>;
				interrupt-controller;
				compatible = "riscv,cpu-intc";
				phandle = <0x02>;
			};
		};
	};

	soc {
		#address-cells = <1>;
		#size-cells = <1>;
		compatible = "simple-bus";
		ranges;

		uart@10000000 {
			compatible = "ns16850";
			reg = <0x10000000 0x100>;
			device_type = "serial";
			clock-frequency = <50000000>;
    		reg-shift = <0>;
    		reg-io-width = <1>;
		};
	};
};